# vLLM Studio Configuration
#
# Zero config:   ./start.sh --direct        (mock inference, no .env needed)
# Real GPU:      Set VLLM_STUDIO_MODELS_DIR, then VLLM_STUDIO_MOCK_INFERENCE=0 ./start.sh --direct
# Full stack:    Set variables below, then ./start.sh (starts Docker services)

# =============================================================================
# Controller
# =============================================================================

# VLLM_STUDIO_HOST=0.0.0.0
# VLLM_STUDIO_PORT=8080
# VLLM_STUDIO_API_KEY=
# VLLM_STUDIO_INFERENCE_PORT=8000
# VLLM_STUDIO_MOCK_INFERENCE=true

# Directory containing model weights (required for real inference)
# VLLM_STUDIO_MODELS_DIR=/models

# VLLM_STUDIO_DATA_DIR=./data

# =============================================================================
# Backend-specific (only if using that backend)
# =============================================================================

# VLLM_STUDIO_SGLANG_PYTHON=/path/to/sglang/venv/bin/python
# VLLM_STUDIO_TABBY_API_DIR=/path/to/tabbyAPI
# VLLM_STUDIO_LLAMA_BIN=/usr/local/bin/llama-server

# =============================================================================
# Docker Services (optional — used by ./start.sh without --direct)
# =============================================================================

# LITELLM_MASTER_KEY=sk-master
# VLLM_STUDIO_LITELLM_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/litellm
# INFERENCE_API_BASE=http://localhost:8000/v1
# INFERENCE_API_KEY=sk-placeholder
# VLLM_STUDIO_TEMPORAL_ADDRESS=localhost:7233

# Linux: match host user to avoid file permission issues with ./data
# VLLM_STUDIO_UID=1000
# VLLM_STUDIO_GID=1000

# =============================================================================
# Frontend
# =============================================================================

# NEXT_PUBLIC_LITELLM_URL=http://localhost:4100

# =============================================================================
# Optional Integrations
# =============================================================================

# GRAFANA_PASSWORD=admin
# EXA_API_KEY=your-exa-api-key-here
