{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "types": ["node"],
    "typeRoots": ["./node_modules/@types"],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@local-studio/agent-runtime": ["../services/agent-runtime/src/index.ts"],
      "@local-studio/agent-runtime/*": ["../services/agent-runtime/src/*.ts"],
      "@local-studio/contracts/*": ["../controller/contracts/*.ts"],
      "@shared/agent/*": ["../shared/agent/*.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "**/*.mts",
    ".next/dev/types/**/*.ts",
    "./.next/types/**/*.ts",
    "./.next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", "knip.ts", "desktop/**", "dist-desktop/**"]
}
