# Frontend Environment Variables

# Backend API URL (controller)
NEXT_PUBLIC_API_URL=http://localhost:8080
BACKEND_URL=http://localhost:8080


# Optional controller API authentication
# Prefer saving this server-side via /api/settings instead of persisting it in the browser.
API_KEY=

# =============================================================================
# Frontend access control
# =============================================================================
# Production web startup fails unless a token or the explicit unauthenticated
# override is configured. Frontend access grants host shell and filesystem
# capability through the in-process coding agent.
#
# Generate a token with `openssl rand -hex 32`, save it below, then enter it on
# the `/access` page. API clients may send the `x-local-studio-token` header.
# Query-string tokens are not accepted. Desktop and `next dev` use their own
# loopback-only or development trust boundaries.
LOCAL_STUDIO_FRONTEND_TOKEN=

# Use only on a trusted network when unauthenticated host access is intentional.
# LOCAL_STUDIO_FRONTEND_ALLOW_UNAUTHENTICATED=false
